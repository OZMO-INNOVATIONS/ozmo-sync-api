# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
APP_NAME=ozmo-sync-api

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES=7d

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://ozmo-sync-devapi.vercel.app

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
