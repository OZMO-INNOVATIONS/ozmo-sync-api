# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=ozmo-sync-api

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate new secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES=7d

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Supabase / Database ──────────────────────────────────────────────────────
# Replace [YOUR-PASSWORD] with your actual Supabase database password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.oouvsosovjztolyrrbps.supabase.co:5432/postgres

# Additional Supabase project environment variables
SUPABASE_URL=https://oouvsosovjztolyrrbps.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
