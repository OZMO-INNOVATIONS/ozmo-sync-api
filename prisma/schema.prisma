generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  firstName       String?        @map("first_name") @db.VarChar(50)
  lastName        String?        @map("last_name") @db.VarChar(50)
  id           String     @id @default(uuid()) @db.Uuid
  workspaceId  String     @map("workspace_id") @db.Uuid
  email        String     @unique @db.VarChar(255)
  password     String     @map("password_hash") @db.Text
  role         Role       @default(STAFF)
  status       UserStatus @default(ACTIVE)
  refreshToken String?    @map("refresh_token") @db.Text
  lastLogin    DateTime?  @map("last_login")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at")

  staffProfile             StaffProfile?
  attendanceSessions       AttendanceSession[]
  attendanceDailySummaries AttendanceDailySummary[]
  leaveRequests            LeaveRequest[]
  taskAssignments          TaskAssignment[]
  notifications            Notification[]
  auditEntries             AuditEntry[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model StaffProfile {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @unique @map("user_id") @db.Uuid
  workspaceId            String    @map("workspace_id") @db.Uuid
  employeeId             String    @unique @map("employee_id") @db.VarChar(30)
  phone                  String?   @db.VarChar(30)
  alternatePhone         String?   @map("alternate_phone") @db.VarChar(30)
  designation            String?   @db.VarChar(100)
  department             String?   @db.VarChar(100)
  reportingManagerId     String?   @map("reporting_manager_id") @db.Uuid
  joiningDate            DateTime? @map("joining_date") @db.Date
  employmentType         String?   @map("employment_type") @db.VarChar(50)
  salary                 Decimal?  @db.Decimal(12, 2)
  gender                 String?   @db.VarChar(20)
  dateOfBirth            DateTime? @map("date_of_birth") @db.Date
  address                String?   @db.Text
  city                   String?   @db.VarChar(100)
  state                  String?   @db.VarChar(100)
  country                String?   @db.VarChar(100)
  postalCode             String?   @map("postal_code") @db.VarChar(20)
  emergencyContactName   String?   @map("emergency_contact_name") @db.VarChar(150)
  emergencyContactNumber String?   @map("emergency_contact_number") @db.VarChar(30)
  profileImage           String?   @map("profile_image") @db.Text
  isFirstLogin           Boolean   @default(true) @map("is_first_login")
  passwordChangedAt      DateTime? @map("password_changed_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportingManager StaffProfile?  @relation("ReportingManager", fields: [reportingManagerId], references: [id])
  subordinates     StaffProfile[] @relation("ReportingManager")

  @@index([employeeId])
  @@index([deletedAt])
  @@map("staff_profiles")
}

model AttendanceSession {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  workspaceId     String    @map("workspace_id") @db.Uuid
  checkInTime     DateTime  @map("check_in_time") @db.Timestamptz(6)
  checkOutTime    DateTime? @map("check_out_time") @db.Timestamptz(6)
  durationMinutes Int?      @map("duration_minutes")
  location        String?   @db.Text
  deviceInfo      String?   @map("device_info") @db.Text
  status          String    @default("ACTIVE") @db.VarChar(30)
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([userId, status])
  @@index([userId, checkInTime])
  @@map("attendance_sessions")
}

model AttendanceDailySummary {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  date              DateTime  @map("date") @db.Date
  firstCheckIn      DateTime? @map("first_check_in") @db.Timestamptz(6)
  lastCheckOut      DateTime? @map("last_check_out") @db.Timestamptz(6)
  totalWorkMinutes  Int       @default(0) @map("total_work_minutes")
  totalBreakMinutes Int       @default(0) @map("total_break_minutes")
  totalSessions     Int       @default(0) @map("total_sessions")
  attendanceStatus  String    @default("PRESENT") @map("attendance_status") @db.VarChar(30)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("attendance_daily_summaries")
}

model Job {
  id                 String          @id @default(uuid()) @db.Uuid
  title              String          @db.VarChar(255)
  department         String          @db.VarChar(100)
  experienceLevel    ExperienceLevel @map("experience_level")
  employmentType     EmploymentType  @map("employment_type")
  description        String
  requirements       String[]
  skills             String[]
  location           String          @db.VarChar(255)
  salaryMin          Int?            @map("salary_min")
  salaryMax          Int?            @map("salary_max")
  currency           String          @default("USD") @db.VarChar(10)
  vacancies          Int             @default(1)
  status             JobStatus       @default(OPEN)
  workspaceId        String          @map("workspace_id") @db.Uuid
  workspaceName      String          @map("workspace_name") @db.VarChar(255)
  hideSalaryPublicly Boolean         @default(false) @map("hide_salary_publicly")
  applicantCount     Int             @default(0) @map("applicant_count")
  closingDate        DateTime?       @map("closing_date") @db.Date
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  candidates         Candidate[]

  @@index([status])
  @@index([department])
  @@map("jobs")
}

model Candidate {
  id                 String          @id @default(uuid()) @db.Uuid
  jobId              String          @map("job_id") @db.Uuid
  firstName          String          @map("first_name") @db.VarChar(50)
  lastName           String          @map("last_name") @db.VarChar(50)
  email              String          @db.VarChar(255)
  phone              String          @db.VarChar(50)
  currentDesignation String          @map("current_designation") @db.VarChar(255)
  experienceYears    Int             @map("experience_years")
  education          String
  skills             String[]
  portfolioUrl       String?         @map("portfolio_url")
  coverLetter        String?         @map("cover_letter")
  resumeUrl          String?         @map("resume_url")
  stage              CandidateStage  @default(APPLIED)
  hasPortalAccess    Boolean         @default(false) @map("has_portal_access")
  source             CandidateSource @default(CAREERS_PORTAL)
  appliedAt          DateTime        @default(now()) @map("applied_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  job                Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([email])
  @@map("candidates")
}

model AuditEntry {
  id          String      @id @default(uuid()) @db.Uuid
  action      AuditAction
  entityType  String      @map("entity_type") @db.VarChar(50)
  entityId    String?     @map("entity_id") @db.Uuid
  actorId     String?     @map("actor_id") @db.Uuid
  actorName   String?     @map("actor_name") @db.VarChar(100)
  ipAddress   String?     @map("ip_address") @db.VarChar(45)
  workspaceId String?     @map("workspace_id") @db.Uuid
  detail      String?
  createdAt   DateTime    @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([actorId])
  @@index([workspaceId])
  @@map("audit_entries")
}

model Workspace {
  id               String        @id @default(uuid()) @db.Uuid
  name             String        @db.VarChar(255)
  domain           String?       @db.VarChar(255)
  plan             WorkspacePlan @default(FREE)
  isActive         Boolean       @default(true) @map("is_active")
  memberCount      Int           @default(0) @map("member_count")
  adminEmail       String?       @map("admin_email") @db.VarChar(255)
  logoUrl          String?       @map("logo_url")
  suspendedAt      DateTime?     @map("suspended_at")
  suspendedBy      String?       @map("suspended_by") @db.VarChar(255)
  suspensionReason String?       @map("suspension_reason")
  unsuspendedAt    DateTime?     @map("unsuspended_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  companyName        String? @map("company_name") @db.VarChar(255)
  businessType       String? @map("business_type") @db.VarChar(100)
  industryType       String? @map("industry_type") @db.VarChar(100)
  companySize        String? @map("company_size") @db.VarChar(50)
  country            String? @db.VarChar(100)
  website            String? @db.VarChar(255)
  companyEmail       String? @map("company_email") @db.VarChar(255)
  companyPhone       String? @map("company_phone") @db.VarChar(50)
  companyAddress     String? @map("company_address")
  companyDescription String? @map("company_description")

  attendanceMethod    String?  @map("attendance_method") @db.VarChar(100)
  defaultWorkingHours String?  @map("default_working_hours") @db.VarChar(100)
  weekendDays         String[] @map("weekend_days")
  leavePolicy         String?  @map("leave_policy")

  pushNotifications Boolean @default(true) @map("push_notifications")
  attendanceAlerts  Boolean @default(true) @map("attendance_alerts")
  leaveAlerts       Boolean @default(true) @map("leave_alerts")
  taskAlerts        Boolean @default(true) @map("task_alerts")
  birthdayAlerts    Boolean @default(true) @map("birthday_alerts")

  @@map("workspaces")
}

model SystemSettings {
  id            String   @id @default(uuid()) @db.Uuid
  branding      Json
  modules       Json
  security      Json
  notifications Json
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedBy     String?  @map("updated_by") @db.VarChar(255)

  @@map("system_settings")
}

model Invitation {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  invitedBy   String    @map("invited_by") @db.Uuid
  name        String    @db.VarChar(255)
  email       String    @db.VarChar(255)
  role        String    @db.VarChar(50)
  tokenHash   String    @unique @map("token_hash") @db.Text
  status      String    @default("pending") @db.VarChar(20)
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([email])
  @@index([tokenHash])
  @@index([workspaceId])
  @@map("invitations")
}

model LeaveType {
  id          String         @id @default(uuid()) @db.Uuid
  workspaceId String         @map("workspace_id") @db.Uuid
  name        String         @db.VarChar(100)
  description String?        @db.Text
  daysAllowed Int            @map("days_allowed")
  isPaid      Boolean        @default(true) @map("is_paid")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  requests    LeaveRequest[]

  @@map("leave_types")
}

model LeaveRequest {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @map("workspace_id") @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  leaveTypeId String      @map("leave_type_id") @db.Uuid
  startDate   DateTime    @map("start_date") @db.Date
  endDate     DateTime    @map("end_date") @db.Date
  reason      String      @db.Text
  status      LeaveStatus @default(PENDING)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@map("leave_requests")
}

model Project {
  id          String          @id @default(uuid()) @db.Uuid
  workspaceId String          @map("workspace_id") @db.Uuid
  name        String          @db.VarChar(255)
  description String?         @db.Text
  status      ProjectStatus   @default(ACTIVE)
  startDate   DateTime?       @map("start_date") @db.Date
  endDate     DateTime?       @map("end_date") @db.Date
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  tasks       Task[]
  members     ProjectMember[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("MEMBER") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Task {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @map("workspace_id") @db.Uuid
  projectId   String       @map("project_id") @db.Uuid
  title       String       @db.VarChar(255)
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date") @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments TaskAssignment[]

  @@map("tasks")
}

model TaskAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@map("task_assignments")
}

model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String   @db.VarChar(255)
  message     String   @db.Text
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  MANAGER
  TEAM_LEAD
  STAFF
  GUEST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  RESIGNED
  TERMINATED
}

enum JobStatus {
  OPEN
  PAUSED
  CLOSED
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum CandidateStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
}

enum CandidateSource {
  CAREERS_PORTAL
  REFERRAL
  MANUAL
}

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_SUSPENDED
  WORKSPACE_UNSUSPENDED
  SETTINGS_UPDATED
  JOB_POSTED
  JOB_CLOSED
  CANDIDATE_APPLIED
  DATA_EXPORTED
  LOGIN
  LOGOUT
  PASSWORD_CHANGED
}

enum WorkspacePlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
