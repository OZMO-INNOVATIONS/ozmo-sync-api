generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  TEAM_LEAD
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  TERMINATED
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum WorkspacePlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  employeeId   String?    @unique @map("employee_id") @db.VarChar(50)
  firstName    String?    @map("first_name") @db.VarChar(50)
  lastName     String?    @map("last_name") @db.VarChar(50)
  email        String     @unique @db.VarChar(255)
  phone        String?    @db.VarChar(30)
  password     String     @map("password_hash") @db.Text
  profilePhoto String?    @map("profile_photo") @db.Text
  isFirstLogin Boolean    @default(true) @map("is_first_login")
  status       UserStatus @default(ACTIVE)
  role         Role       @default(STAFF)
  lastLogin    DateTime?  @map("last_login")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")
  createdBy    String?    @map("created_by") @db.Uuid
  updatedBy    String?    @map("updated_by") @db.Uuid
  workspaceId  String?    @map("workspace_id") @db.Uuid

  alternatePhone         String?   @map("alternate_phone") @db.VarChar(30)
  designation            String?   @db.VarChar(100)
  department             String?   @db.VarChar(100)
  reportingManagerId     String?   @map("reporting_manager_id") @db.Uuid
  joiningDate            DateTime? @map("joining_date") @db.Date
  employmentType         String?   @map("employment_type") @db.VarChar(50)
  salary                 Decimal?  @db.Decimal(12, 2)
  gender                 String?   @db.VarChar(20)
  dateOfBirth            DateTime? @map("date_of_birth") @db.Date
  address                String?   @db.Text
  city                   String?   @db.VarChar(100)
  state                  String?   @db.VarChar(100)
  country                String?   @db.VarChar(100)
  postalCode             String?   @map("postal_code") @db.VarChar(20)
  emergencyContactName   String?   @map("emergency_contact_name") @db.VarChar(150)
  emergencyContactNumber String?   @map("emergency_contact_number") @db.VarChar(30)
  emergencyContactRelation String? @map("emergency_contact_relation") @db.VarChar(50)
  bloodGroup             String?   @map("blood_group") @db.VarChar(20)
  maritalStatus          String?   @map("marital_status") @db.VarChar(50)
  nationality            String?   @db.VarChar(100)
  probationEndDate       DateTime? @map("probation_end_date") @db.Date
  workLocation           String?   @map("work_location") @db.VarChar(100)
  bio                    String?   @db.Text
  passwordChangedAt      DateTime? @map("password_changed_at")

  memberships        WorkspaceMember[]
  ownedWorkspaces    Workspace[]          @relation("WorkspaceOwner")
  attendanceRecords  Attendance[]
  attendanceSessions AttendanceSession[]
  leaveRequests      LeaveRequest[]       @relation("UserLeaveRequests")
  approvedLeaves     LeaveRequest[]       @relation("ApprovedByLeaveRequests")
  leaveApprovals     LeaveApproval[]      @relation("ApproverLeaveApprovals")
  leaveBalances      LeaveBalance[]
  managedProjects    Project[]            @relation("ProjectManager")
  projectMemberships ProjectMember[]
  assignedTasks      Task[]               @relation("TaskAssignee")
  createdTasks       Task[]               @relation("TaskCreator")
  taskComments       TaskComment[]
  createdMeetings    Meeting[]            @relation("MeetingCreator")
  meetingAttendance  MeetingParticipant[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  activityLogs       ActivityLog[]
  sessions           UserSession[]
  refreshTokens      RefreshToken[]
  regularizations         AttendanceRegularization[] @relation("UserRegularizations")
  approvedRegularizations AttendanceRegularization[] @relation("ApprovedByRegularizations")
  documents               EmployeeDocument[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model Workspace {
  id            String          @id @default(uuid()) @db.Uuid
  workspaceCode String          @unique @map("workspace_code") @db.VarChar(50)
  name          String          @db.VarChar(255)
  slug          String          @unique @db.VarChar(255)
  logoUrl       String?         @map("logo_url") @db.Text
  ownerId       String          @map("owner_id") @db.Uuid
  subscriptionId String?        @map("subscription_id") @db.Uuid
  status        WorkspaceStatus @default(ACTIVE)
  plan          WorkspacePlan   @default(FREE)
  adminEmail    String?         @map("admin_email") @db.VarChar(255)
  isActive      Boolean         @default(true) @map("is_active")
  memberCount   Int             @default(0) @map("member_count")
  domain        String?         @db.VarChar(255)
  allowedWifiIp String?         @map("allowed_wifi_ip") @db.VarChar(100)
  latitude      Float?
  longitude     Float?
  geofenceRadius Float?         @default(100) @map("geofence_radius")
  suspendedAt   DateTime?       @map("suspended_at")
  suspendedBy   String?         @map("suspended_by") @db.VarChar(255)
  suspensionReason String?       @map("suspension_reason")
  unsuspendedAt DateTime?       @map("unsuspended_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")
  createdBy     String?         @map("created_by") @db.Uuid
  updatedBy     String?         @map("updated_by") @db.Uuid

  owner             User                @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members           WorkspaceMember[]
  settings          WorkspaceSettings?
  departments       Department[]
  designations      Designation[]
  attendance        Attendance[]
  attendanceSessions AttendanceSession[]
  leaveTypes        LeaveType[]
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
  leaveApprovals    LeaveApproval[]
  projects          Project[]
  projectMembers    ProjectMember[]
  tasks             Task[]
  taskComments      TaskComment[]
  meetings          Meeting[]
  meetingParticipants MeetingParticipant[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  activityLogs      ActivityLog[]
  subscriptions     Subscription[]
  billing           WorkspaceBilling[]
  files             File[]
  sessions          UserSession[]
  holidays          Holiday[]
  regularizations   AttendanceRegularization[]

  @@map("workspaces")
}

model WorkspaceMember {
  id                 String     @id @default(uuid()) @db.Uuid
  workspaceId        String     @map("workspace_id") @db.Uuid
  userId             String     @map("user_id") @db.Uuid
  role               Role       @default(STAFF)
  departmentId       String?    @map("department_id") @db.Uuid
  designationId      String?    @map("designation_id") @db.Uuid
  reportingManagerId String?    @map("reporting_manager_id") @db.Uuid
  joiningDate        DateTime?  @map("joining_date") @db.Date
  isPrimary          Boolean    @default(false) @map("is_primary")
  status             UserStatus @default(INVITED)
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @default(now()) @updatedAt @map("updated_at")
  deletedAt          DateTime?  @map("deleted_at")
  createdBy          String?    @map("created_by") @db.Uuid
  updatedBy          String?    @map("updated_by") @db.Uuid

  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  department       Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation      Designation?     @relation(fields: [designationId], references: [id], onDelete: SetNull)
  reportingManager WorkspaceMember? @relation("ReportingManager", fields: [reportingManagerId], references: [id])
  subordinates     WorkspaceMember[] @relation("ReportingManager")

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model WorkspaceSettings {
  id            String    @id @default(uuid()) @db.Uuid
  workspaceId   String    @unique @map("workspace_id") @db.Uuid
  branding      Json?
  modules       Json?
  security      Json?
  notifications Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_settings")
}

model Department {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String    @db.VarChar(100)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   WorkspaceMember[]

  @@map("departments")
}

model Designation {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String    @db.VarChar(100)
  level       Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   WorkspaceMember[]

  @@map("designations")
}

model Attendance {
  id              String    @id @default(uuid()) @db.Uuid
  workspaceId     String    @map("workspace_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  date            DateTime  @db.Date
  checkIn         DateTime? @map("check_in")
  checkOut        DateTime? @map("check_out")
  breakMinutes    Int       @default(0) @map("break_minutes")
  workedMinutes   Int       @default(0) @map("worked_minutes")
  overtimeMinutes Int       @default(0) @map("overtime_minutes")
  lateMinutes     Int       @default(0) @map("late_minutes")
  status          String    @db.VarChar(50)
  verificationType String?   @map("verification_type") @db.VarChar(50)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  createdBy       String?   @map("created_by") @db.Uuid
  updatedBy       String?   @map("updated_by") @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("attendance")
}

model AttendanceSession {
  id              String    @id @default(uuid()) @db.Uuid
  workspaceId     String    @map("workspace_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  checkInTime     DateTime  @map("check_in_time")
  checkOutTime    DateTime? @map("check_out_time")
  durationMinutes Int?      @map("duration_minutes")
  location        String?   @db.Text
  deviceInfo      String?   @map("device_info") @db.Text
  status          String    @default("ACTIVE") @db.VarChar(30)
  verificationType String?  @map("verification_type") @db.VarChar(50)
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  createdBy       String?   @map("created_by") @db.Uuid
  updatedBy       String?   @map("updated_by") @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("attendance_sessions")
}

model LeaveType {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String    @db.VarChar(100)
  description String?   @db.Text
  daysAllowed Int       @map("days_allowed")
  isPaid      Boolean   @default(true) @map("is_paid")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requests  LeaveRequest[]
  balances  LeaveBalance[]

  @@map("leave_types")
}

model LeaveBalance {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  leaveTypeId String    @map("leave_type_id") @db.Uuid
  balance     Float     @default(0)
  used        Float     @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveTypeId])
  @@map("leave_balances")
}

model LeaveRequest {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  leaveTypeId String    @map("leave_type_id") @db.Uuid
  fromDate    DateTime  @map("from_date") @db.Date
  toDate      DateTime  @map("to_date") @db.Date
  days        Float
  reason      String    @db.Text
  status      String    @default("PENDING") @db.VarChar(50)
  approvedBy  String?   @map("approved_by") @db.Uuid
  approvedAt  DateTime? @map("approved_at")
  rejectionReason String? @map("rejection_reason") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User            @relation("UserLeaveRequests", fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType       @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  approver  User?           @relation("ApprovedByLeaveRequests", fields: [approvedBy], references: [id], onDelete: SetNull)
  approvals LeaveApproval[]

  @@map("leave_requests")
}

model LeaveApproval {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  leaveRequestId String    @map("leave_request_id") @db.Uuid
  approvedBy     String    @map("approved_by") @db.Uuid
  approvalLevel  String    @map("approval_level") @db.VarChar(50)
  decision       String    @db.VarChar(50)
  remarks        String?   @db.Text
  approvedAt     DateTime  @map("approved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  approver     User         @relation("ApproverLeaveApprovals", fields: [approvedBy], references: [id], onDelete: Cascade)

  @@map("leave_approvals")
}

model Project {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceId      String    @map("workspace_id") @db.Uuid
  name             String    @db.VarChar(255)
  description      String?   @db.Text
  startDate        DateTime? @map("start_date") @db.Date
  endDate          DateTime? @map("end_date") @db.Date
  status           String    @default("ACTIVE") @db.VarChar(50)
  projectManagerId String?   @map("project_manager_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  createdBy        String?   @map("created_by") @db.Uuid
  updatedBy        String?   @map("updated_by") @db.Uuid

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectManager User?           @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)
  members        ProjectMember[]
  tasks          Task[]

  @@map("projects")
}

model ProjectMember {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  role        String    @default("MEMBER") @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Task {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  assignedTo  String?   @map("assigned_to") @db.Uuid
  assignedBy  String?   @map("assigned_by") @db.Uuid
  title       String    @db.VarChar(255)
  description String?   @db.Text
  priority    String    @default("MEDIUM") @db.VarChar(30)
  status      String    @default("TODO") @db.VarChar(30)
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee  User?         @relation("TaskAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator   User?         @relation("TaskCreator", fields: [assignedBy], references: [id], onDelete: SetNull)
  comments  TaskComment[]

  @@map("tasks")
}

model TaskComment {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  taskId      String    @map("task_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  comment     String    @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model Meeting {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  createdBy   String    @map("created_by") @db.Uuid
  title       String    @db.VarChar(255)
  description String?   @db.Text
  meetingLink String    @map("meeting_link") @db.Text
  meetingDate DateTime  @map("meeting_date")
  duration    String    @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  updatedBy   String?   @map("updated_by") @db.Uuid

  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator      User                 @relation("MeetingCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]

  @@map("meetings")
}

model MeetingParticipant {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  meetingId   String    @map("meeting_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  attended    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@map("meeting_participants")
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  title       String    @db.VarChar(255)
  message     String    @db.Text
  type        String    @db.VarChar(50)
  isRead      Boolean   @default(false) @map("is_read")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  actionId    String?   @map("action_id") @db.VarChar(100)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String?   @map("workspace_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  module      String    @db.VarChar(100)
  action      String    @db.VarChar(100)
  oldData     Json?     @map("old_data")
  newData     Json?     @map("new_data")
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model ActivityLog {
