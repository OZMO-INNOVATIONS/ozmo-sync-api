  branding      Json
  modules       Json
  security      Json
  notifications Json
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedBy     String?  @map("updated_by") @db.VarChar(255)

  @@map("system_settings")
}

model Invitation {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  invitedBy   String    @map("invited_by") @db.Uuid
  name        String    @db.VarChar(255)
  email       String    @db.VarChar(255)
  role        String    @db.VarChar(50)
  tokenHash   String    @unique @map("token_hash") @db.Text
  status      String    @default("pending") @db.VarChar(20)
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([email])
  @@index([tokenHash])
  @@index([workspaceId])
  @@map("invitations")
}

model Job {
  id                 String          @id @default(uuid()) @db.Uuid
  title              String          @db.VarChar(255)
  department         String          @db.VarChar(100)
  experienceLevel    ExperienceLevel @map("experience_level")
  employmentType     EmploymentType  @map("employment_type")
  description        String
  requirements       String[]
  skills             String[]
  location           String          @db.VarChar(255)
  salaryMin          Int?            @map("salary_min")
  salaryMax          Int?            @map("salary_max")
  currency           String          @default("USD") @db.VarChar(10)
  vacancies          Int             @default(1)
  status             JobStatus       @default(OPEN)
  workspaceId        String          @map("workspace_id") @db.Uuid
  workspaceName      String          @map("workspace_name") @db.VarChar(255)
  hideSalaryPublicly Boolean         @default(false) @map("hide_salary_publicly")
  applicantCount     Int             @default(0) @map("applicant_count")
  closingDate        DateTime?       @map("closing_date") @db.Date
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  candidates         Candidate[]

  @@index([status])
  @@index([department])
  @@map("jobs")
}

model Candidate {
  id                 String          @id @default(uuid()) @db.Uuid
  jobId              String          @map("job_id") @db.Uuid
  firstName          String          @map("first_name") @db.VarChar(50)
  lastName           String          @map("last_name") @db.VarChar(50)
  email              String          @db.VarChar(255)
  phone              String          @db.VarChar(50)
  currentDesignation String          @map("current_designation") @db.VarChar(255)
  experienceYears    Int             @map("experience_years")
  education          String
  skills             String[]
  portfolioUrl       String?         @map("portfolio_url")
  coverLetter        String?         @map("cover_letter")
  resumeUrl          String?         @map("resume_url")
  stage              CandidateStage  @default(APPLIED)
  hasPortalAccess    Boolean         @default(false) @map("has_portal_access")
  source             CandidateSource @default(CAREERS_PORTAL)
  appliedAt          DateTime        @default(now()) @map("applied_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  job                Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([email])
  @@map("candidates")
}

enum JobStatus {
  OPEN
  PAUSED
  CLOSED
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum CandidateStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
}

enum CandidateSource {
  CAREERS_PORTAL
  REFERRAL
  MANUAL
}

model Holiday {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String?   @map("workspace_id") @db.Uuid
  name         String    @db.VarChar(255)
  date         DateTime  @db.Date
  type         String    @default("publicHoliday") @db.VarChar(50)
  description  String?   @db.Text
  notes        String?   @db.Text
  repeatYearly Boolean   @default(true) @map("repeat_yearly")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("holidays")
}

enum RegularizationType {
  CHECK_IN
  CHECK_OUT
  BOTH
}

enum RegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

model AttendanceRegularization {
  id              String               @id @default(uuid()) @db.Uuid
  workspaceId     String               @map("workspace_id") @db.Uuid
  userId          String               @map("user_id") @db.Uuid
  date            DateTime             @db.Date
  type            RegularizationType
  checkIn         DateTime?            @map("check_in")
  checkOut        DateTime?            @map("check_out")
  reason          String               @db.Text
  status          RegularizationStatus @default(PENDING)
  rejectionReason String?              @map("rejection_reason") @db.Text
  approvedById    String?              @map("approved_by_id") @db.Uuid
  approvedAt      DateTime?            @map("approved_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @default(now()) @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation("UserRegularizations", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy User?    @relation("ApprovedByRegularizations", fields: [approvedById], references: [id])

  @@map("attendance_regularizations")
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  UPDATE_REQUESTED
  REUPLOAD_REQUESTED
}

model EmployeeDocument {
  id              String         @id @default(uuid()) @db.Uuid
  employeeId      String         @map("employee_id") @db.Uuid
  documentType    String         @map("document_type") @db.VarChar(100)
  name            String         @db.VarChar(255)
  fileUrl         String         @map("file_url") @db.Text
  status          DocumentStatus @default(PENDING)
  rejectionReason String?        @map("rejection_reason") @db.Text
  uploadDate      DateTime       @default(now()) @map("upload_date")
  expiryDate      DateTime?      @map("expiry_date")
  approvalDate    DateTime?      @map("approval_date")
  updatedDate     DateTime?      @map("updated_date")
  isCurrent       Boolean        @default(true) @map("is_current")
  version         Int            @default(1)
  parentId        String?        @map("parent_id") @db.Uuid

  employee        User           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  updateRequests  DocumentUpdateRequest[]

  @@map("employee_documents")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model DocumentUpdateRequest {
  id           String        @id @default(uuid()) @db.Uuid
  documentId   String        @map("document_id") @db.Uuid
  employeeId   String        @map("employee_id") @db.Uuid
  reason       String        @db.Text
  newFileUrl   String        @map("new_file_url") @db.Text
  newFileName  String        @map("new_file_name") @db.VarChar(255)
  status       RequestStatus @default(PENDING)
  createdAt    DateTime      @default(now()) @map("created_at")
  resolvedAt   DateTime?     @map("resolved_at")
  resolvedBy   String?       @map("resolved_by") @db.Uuid

  document     EmployeeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_update_requests")
}
