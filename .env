# ─── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=ozmo-auth-api

# ─── JWT ─────────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_secret
JWT_REFRESH_EXPIRES=7d

# ─── Security ─────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── CORS ─────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# ─── Rate Limiting ────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Supabase (existing project vars — kept for compatibility) ────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.mpwtahsuselyglczgrdv.supabase.co:5432/postgres
SUPABASE_URL=https://mpwtahsuselyglczgrdv.supabase.co
SUPABASE_ANON_KEY=sb_publishable_yYF_Qxyyuap1fNgzyrhhug_4C7Wy7uh
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
