{
  "info": {
    "name": "Ozmo Sync API — Industrial Grade Tests",
    "description": "Comprehensive test suite covering all endpoints, happy paths, error scenarios, RBAC, edge cases, and data validation.\n\nRun with Newman:\n  npx newman run postman/ozmo-sync-api-tests.postman_collection.json -e postman/ozmo-sync-api.environment.json --delay-request 300",
    "schema": "https://schema.getpostman.com/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000", "type": "string" },
    { "key": "uniqueEmail", "value": "", "type": "string" },
    { "key": "uniqueName", "value": "", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "adminAccessToken", "value": "", "type": "string" },
    { "key": "userAccessToken", "value": "", "type": "string" },
    { "key": "regUserAccessToken", "value": "", "type": "string" },
    { "key": "regUserRefreshToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🩺 1. Health & Server Checks",
      "item": [
        {
          "name": "GET /health",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const body = pm.response.json();",
                "",
                "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
                "pm.test('Response time < 500ms', () => pm.expect(pm.response.responseTime).to.be.below(500));",
                "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                "pm.test('Has CORS header', () => pm.expect(pm.response.headers.get('access-control-allow-origin')).to.exist);",
                "pm.test('No X-Powered-By header', () => pm.expect(pm.response.headers.get('x-powered-by')).to.not.exist);",
                "",
                "pm.test('Schema matches', () => {",
                "  pm.expect(body).to.have.property('success', true);",
                "  pm.expect(body).to.have.property('message', 'Service is healthy');",
                "  pm.expect(body).to.have.property('app');",
                "  pm.expect(body).to.have.property('env');",
                "  pm.expect(body).to.have.property('timestamp');",
                "  pm.expect(body.env).to.be.oneOf(['development', 'production', 'test']);",
                "  pm.expect(body.timestamp).to.match(/^\\d{4}-\\d{2}-\\d{2}T/);",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "GET /api/v1/unknown — 404",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const body = pm.response.json();",
                "pm.test('Status 404', () => pm.expect(pm.response.code).to.eql(404));",
                "pm.test('Correct error format', () => {",
                "  pm.expect(body).to.have.property('success', false);",
                "  pm.expect(body.message).to.include('not found');",
                "  pm.expect(body).to.have.property('timestamp');",
                "  pm.expect(body).to.not.have.property('data');",
                "});"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/nonexistent-route", "host": ["{{baseUrl}}"], "path": ["api", "v1", "nonexistent-route"] }
          }
        }
      ]
    },
    {
      "name": "🔐 2. Authentication Flow",
      "item": [
        {
          "name": "POST /auth/register — Create user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const ts = Date.now();",
                  "const rnd = Math.floor(Math.random() * 100000);",
                  "pm.collectionVariables.set('uniqueEmail', `autotest.${ts}.${rnd}@ozmo.io`);",
                  "pm.collectionVariables.set('uniqueName', `Auto Test ${rnd}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "",
                  "pm.test('Status 201', () => pm.expect(pm.response.code).to.eql(201));",
                  "pm.test('Response time < 1000ms', () => pm.expect(pm.response.responseTime).to.be.below(1000));",
                  "pm.test('Registration successful', () => {",
                  "  pm.expect(body).to.have.property('success', true);",
                  "  pm.expect(body).to.have.property('message', 'Registration successful');",
                  "  pm.expect(body.data).to.have.property('accessToken');",
                  "  pm.expect(body.data).to.have.property('refreshToken');",
                  "});",
                  "pm.test('User object is valid', () => {",
                  "  const user = body.data.user;",
                  "  pm.expect(user).to.have.property('id');",
                  "  pm.expect(user).to.have.property('name');",
                  "  pm.expect(user).to.have.property('email');",
                  "  pm.expect(user.email).to.match(/@ozmo\\.io$/);",
                  "  pm.expect(user).to.have.property('role', 'user');",
                  "  pm.expect(user).to.have.property('createdAt');",
                  "  pm.expect(user).to.not.have.property('password');",
                  "  pm.expect(user).to.not.have.property('isBlocked');",
                  "});",
                  "pm.test('Tokens are valid JWTs', () => {",
                  "  pm.expect(body.data.accessToken).to.match(/^[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+$/);",
                  "  pm.expect(body.data.refreshToken).to.match(/^[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+$/);",
                  "});",
                  "",
                  "pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "pm.collectionVariables.set('regUserAccessToken', body.data.accessToken);",
                  "pm.collectionVariables.set('regUserRefreshToken', body.data.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{uniqueName}}\",\n  \"email\": \"{{uniqueEmail}}\",\n  \"password\": \"Secure@789\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] }
          }
        },
