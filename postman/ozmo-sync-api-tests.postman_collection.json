    {
      "name": "🛡️ 4. Admin Operations & RBAC",
      "item": [
        {
          "name": "GET /admin/users — As admin (200)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const body = pm.response.json();",
                "",
                "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
                "pm.test('Users retrieved', () => {",
                "  pm.expect(body).to.have.property('success', true);",
                "  pm.expect(body).to.have.property('message', 'Users retrieved successfully');",
                "  pm.expect(body.data.users).to.be.an('array');",
                "  pm.expect(body.data.users.length).to.be.at.least(4);",
                "  pm.expect(body.data).to.have.property('total');",
                "});",
                "pm.test('Users have no password field', () => {",
                "  body.data.users.forEach(user => {",
                "    pm.expect(user).to.not.have.property('password');",
                "  });",
                "});",
                "pm.test('Contains seed users', () => {",
                "  const emails = body.data.users.map(u => u.email);",
                "  pm.expect(emails).to.include.members(['alice@ozmo.io', 'bob@ozmo.io']);",
                "});"
              ],
              "type": "text/javascript"
