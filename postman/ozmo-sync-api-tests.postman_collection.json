        {
          "name": "GET /user/profile — Admin token",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const body = pm.response.json();",
                "",
                "pm.test('Status 200', () => pm.expect(pm.response.code).to.eql(200));",
                "pm.test('Profile returned', () => {",
                "  pm.expect(body).to.have.property('success', true);",
                "  pm.expect(body).to.have.property('message', 'Profile fetched successfully');",
                "  pm.expect(body.data).to.have.property('user');",
                "});",
                "pm.test('User has expected fields', () => {",
                "  const user = body.data.user;",
                "  pm.expect(user).to.have.all.keys('id', 'name', 'email', 'role', 'createdAt');",
                "  pm.expect(user).to.not.have.property('password');",
                "  pm.expect(user).to.not.have.property('isBlocked');",
                "  pm.expect(user.id).to.be.a('number');",
                "  pm.expect(user.role).to.eql('admin');",
                "});"
